SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=hr@yourdomain.com
SENDER_NAME=Nippon Toyota HR
COMPANY_NAME=Nippon Toyota
COMPANY_EMAIL=hr@yourdomain.com
COMPANY_PHONE=+91-00000-00000
COMPANY_ADDRESS=Your office address
# Optional: logo in email header (public https URL)
# COMPANY_LOGO_URL=https://yourdomain.com/logo.png

# Local development (SQLite is used automatically when DATABASE_URL is unset)
FLASK_ENV=development
FLASK_DEBUG=1
MAX_SLIPS_PER_REQUEST=50

# Database (optional)
# Omit DATABASE_URL locally — app uses salary_system.db in the project folder.
# On Render, DATABASE_URL is auto-set when a PostgreSQL database is linked.
# DATABASE_URL=postgresql://user:password@host:5432/salary_system
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@host:5432/salary_system

# Optional production tuning (Render)
# INSTANCE_PATH=/tmp
# SENDGRID_TIMEOUT=30
# GUNICORN_TIMEOUT=120
# WEB_CONCURRENCY=1
# GUNICORN_THREADS=2
# MAX_UPLOAD_MB=8
# LOG_LEVEL=info
